# Github App
APP_ID=your_github_app_id
WEBHOOK_SECRET=your_webhook_secret
PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----
your_rsa_private_key_here
-----END RSA PRIVATE KEY-----"

# Thirdweb
CLIENT_ID=your_thirdweb_client_id
CLIENT_SECRET=your_thirdweb_client_secret

# Wallet that signs blockchain transactions (needs Base Sepolia ETH for gas)
# Create a new wallet and fund it: https://faucet.quicknode.com/base/sepolia
WALLET_PRIVATE_KEY=your_wallet_private_key

PORT=3000
HOST=localhost
